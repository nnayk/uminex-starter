{{ 'product-featured.css' | asset_url | stylesheet_tag }}

{% liquid
  assign sid = section.id
  assign layout = section.settings.layout
  assign product = section.settings.product
  assign sett_equal = settings.use_eq_height_product
  assign image_ratio = settings.image_ratio_product
  if sett_equal
    case image_ratio
      when 'ratio2_1'
        assign aspect_ratio = 2.0
      when 'ratio3_2'
        assign aspect_ratio = 1.5
      when 'ratio4_3'
        assign aspect_ratio = 1.333
      when 'ratio5_6'
        assign aspect_ratio = 0.8333
      when 'ratio1_1'
        assign aspect_ratio = 1.0
      when 'ratio6_5'
        assign aspect_ratio = 1.2
      when 'ratio3_4'
        assign aspect_ratio = 0.75
      when 'ratio2_3'
        assign aspect_ratio = 0.66667
      when 'ratio1_2'
        assign aspect_ratio = 0.5
      when 'custom'
        assign custom_ratio = settings.custom_ratio | split: '/'
        assign width = custom_ratio[0]
        assign height = custom_ratio[1] | times: 1.0
        assign aspect_ratio = width | divided_by: height
    endcase
  endif
%}
{%- capture style -%}
  {% assign ratio = aspect_ratio | default:product.featured_media.aspect_ratio %}
  --ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;
{%- endcapture -%}
<section
  id="laber_{{sid}}"
  class="wow animate--slide-in {% if section.settings.use_border_for_product %}alo-border-product{% endif%}"
>
  <div
    class="container {% if layout %}full-width{% endif %} "
    style="--alo-container-width:{{ section.settings.container }}px;"
    data-js-product
  >
    <script class="data-json-product" type="application/json">
      {% render 'product-get-attributes', product:product, build_variant: 'json' %}
    </script>
    {% if section.settings.title != blank %}
      <div class="wrap_title {{ section.settings.text_size }} w_{{ section.settings.d_position }}">
        <div
          class="h3 section-title alo-text-transform"
          style="--alo-text-transform:{{ section.settings.text_transform }}"
        >
          {{ section.settings.title }}
        </div>
        {% if section.settings.content != blank %}
          <div class="content">{{ section.settings.content }}</div>
        {% endif %}
      </div>
    {% endif %}
    {%- assign product_form_id = 'product-form-' | append: section.id -%}
    {%- form 'product',
      product,
      id: product_form_id,
      class: 'form',
      novalidate: 'novalidate',
      data-type: 'add-to-cart-form'
    -%}
      <input type="hidden" name="id" value="{{ current_variant.id }}" data-js-product-variant-input>
      <div class="row" style="--alo-gap:{{ section.settings.gap }}px;--alo-row:-{{ section.settings.gap }}px;">
        {%- include 'product-featured', product: product, style: style -%}
      </div>
    {% endform %}
  </div>
  {% if section.settings.show_border %}
    <div
      class="sm:d-none pt-100 sm:pt-50 container {% if layout %}full-width{% endif %}"
      style="--alo-container-width:{{ section.settings.container }}px;"
    >
      <div class="line alo-background-color" style="--alo-background-color:{{ section.settings.cl_line }};"></div>
    </div>
  {% endif %}
</section>
<script type="text/javascript">
  document.addEventListener("DOMContentLoaded", function() {
      if(window.Shopify?.PaymentButton?.init) Shopify.PaymentButton.init();
  });
</script>
{%- render 'section_style' -%}
{%- schema -%}
{
  "name": "Product featured",
  "class": "shopify-section cms_section product_section product_featured",
  "settings": [
    {
      "type": "header",
      "content": "== Title Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Product featured"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "Commodo sociosqu venenatis cras dolor sagittis integer luctus maecenas."
    },
    {
      "type": "select",
      "id": "text_size",
      "default": "medium",
      "options": [
        {
          "value": "small",
          "label": "small"
       },
       {
          "value": "medium",
          "label": "Medium"
       },
       {
          "value": "large",
          "label": "Large"
        }
      ],
      "label": "Text size"
    },
    {
            "type": "select",
            "id": "text_transform",
            "default": "none",
            "options": [
             {
                "value": "none",
                "label": "None"
             },
             {
                "value": "capitalize",
                "label": "Capitalize"
             },
             {
                "value": "lowercase",
                "label": "Lowercase"
             },
             {
                "value": "uppercase",
                "label": "Uppercase"
              }
            ],
            "label": "Text transform:"
          },
    {
        "type": "select",
        "id": "d_position",
        "label": "Display position",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Center"
          },
          {
            "value": "right",
            "label": "Right"
          }
        ],
        "default": "center"
      },
    {
      "type": "header",
      "content": "== Product Settings"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "== Product information"
    },
    {
       "type": "checkbox",
       "id": "show_popup",
       "label": "Show terms and conditions",
       "default": true
     },
      {
      "type": "url",
      "id": "product_terms_conditions_page_content",
      "label": "Content for 'terms and conditions'"
    },
    {
      "type": "header",
      "content": "== Design Options"
    },
    {
    "type": "checkbox",
    "id": "layout",
    "label": "Full width",
    "default": false
    },
    {
        "type": "range",
        "id": "container",
        "label": "Container width",
        "min": 1170,
        "max": 1920,
        "step": 10,
        "unit": "px",
        "default": 1410
    },
    {
        "type": "range",
        "id": "gap",
        "label": "Gap",
        "min": 0,
        "max": 30,
        "step": 1,
        "unit": "px",
        "default": 30
    },
    {
      "type": "color",
      "id": "cl_bg",
      "label": "Background color",
      "default": "#fff"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show Border",
      "default": false
    },
   {
      "type": "color",
      "id": "cl_line",
      "label": "Color line",
      "default": "#fff"
    },

 {
      "type": "header",
      "content": "== Margin",
"info":"Margin top, margin bottom. If you not use to blank"
    },
 	        {
      "type": "text",
      "id": "mg",
      "label": "Margin",
      "info":"Margin top, margin right, margin bottom, margin left. If you not use to blank"
    },
    {
      "type": "text",
      "id": "pd",
      "label": "Padding",
      "info":"Padding top, padding right, padding bottom, padding left. If you not use to blank"
    },
   {
      "type": "header",
      "content": "== Design Mobile Options"
    },
    {
      "type": "text",
      "id": "mg_mb",
      "label": "Margin"
    },
    {
      "type": "text",
      "id": "pd_mb",
      "label": "Padding"
    }

  ],
  "presets": [
    {
      "name": "Product featured",
      "category": "Product"
    }
  ]
}
{%- endschema -%}
