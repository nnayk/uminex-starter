{%- liquid
  assign url = block.settings.url | default:'#' 
  assign image = block.settings.image | default: url.object.image | default: url.object.products[0].featured_image
  assign name = block.settings.title
-%}
<div id="bk_{{block.id}}" class="sub_coll_item sub_coll_{{for_i}}" {{ block.shopify_attributes }} >
  <div class="sub_coll_item__content">
    <div class="sub_coll_item__link">
        {%- if image != blank -%}
          {% render 'responsive-image', image: image, url:url, aspect_ratio:aspect_ratio,border:section.settings.border, image_class: 'w-full h-full' %}
        {%- else -%}
          {% if aspect_ratio != blank %}
               {%- assign ratio =  1 | divided_by: aspect_ratio | times: 100 -%}
            {% else %}
                {%- assign ratio = 100 -%}
            {% endif %}
            <div class="image-card__img overflow-hidden ratio" style="--ratio-percent: {{ ratio }}%;">
              {% capture current %}{% cycle 1, 2, 3, 4 %}{% endcapture %}
               {{ 'collection-apparel-' | append: current | placeholder_svg_tag: 'placeholder-svg w-full h-full' }}
            </div>
        {%- endif -%}
        <div class="content">
          <div class="collection-name">
              <a href="{{ url }}" title="{{ name }}" aria-label="link" >{{ name }}</a>
          </div>
        </div>
    </div>
  </div>
</div>



